# Copy this file to `.env.local` (same folder as package.json) and set your real URL.
#
# Rules:
# - No quotes around the value
# - Must be a full URL starting with https://
# - No trailing spaces
# - Restart `npm run dev` after any change (Next only reads env at startup)
#
# Deploying (Vercel, etc.): add NEXT_PUBLIC_FUNNEL_OUT_URL in the host dashboard too.

NEXT_PUBLIC_FUNNEL_OUT_URL=https://your-actual-affiliate-link.com
