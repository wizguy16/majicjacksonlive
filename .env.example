# Copy to `.env.local` (project root, next to package.json).
#
# Prefer this (server-only — picked up on every request, not baked at compile time):
FUNNEL_OUT_URL=https://stripchat.com/majicjackson/follow-me
#
# Optional fallback (can be omitted if FUNNEL_OUT_URL is set):
# NEXT_PUBLIC_FUNNEL_OUT_URL=https://stripchat.com/majicjackson/follow-me
#
# Rules: no quotes, full https:// URL, no trailing spaces.
# After changes: stop dev server, run `rm -rf .next`, then `npm run dev`
#
# Vercel: add FUNNEL_OUT_URL in Project → Settings → Environment Variables.
